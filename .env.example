# COE env for self-host prod
# copy to .env and source or use in docker

DOMAIN=ka.example.com
COE_KA_ADMIN_TOKEN=replace-with-strong-random-32bytes+
EXTERNAL_IP=your.server.ip
COE_TURN_USER=coe
COE_TURN_PASS=strong-turn-pass

